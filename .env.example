# Copy this file to .env and fill in real values. .env is gitignored.
# Generate secrets with:  openssl rand -base64 48
# PowerShell: [Convert]::ToBase64String((1..36 | ForEach-Object {Get-Random -Max 256}))

# Base domain for all hostnames: portal.<BASE_DOMAIN>, auth.<BASE_DOMAIN>, etc.
# - Local development: localhost  (browsers resolve *.localhost automatically)
# - AWS VM without DNS: <public-ip-with-dashes>.sslip.io   e.g. 52-1-2-3.sslip.io
BASE_DOMAIN=localhost

# PostgreSQL password for Authentik's database (max 99 characters).
PG_PASS=CHANGE_ME

# Authentik cryptographic secret key. Generate once, never change afterwards.
AUTHENTIK_SECRET_KEY=CHANGE_ME

# Initial password for the built-in Authentik admin user 'akadmin'.
# Only read on the very first startup (empty database).
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com

# Flask session-signing key for the portal.
PORTAL_SECRET_KEY=CHANGE_ME

# Hostnames covered by the generated TLS certificate. Only set this when you
# add an application (append its subdomain); certs regenerate on next startup.
#CERT_SUBDOMAINS=auth portal factorydocs inventory finance maintenance

# OIDC client credentials for the portal. You get these from Authentik AFTER
# the one-time setup (README step "Create the portal OIDC provider").
# Leave as-is for the very first startup, fill in later, then:
#   docker compose up -d portal
OIDC_CLIENT_ID=not-configured-yet
OIDC_CLIENT_SECRET=not-configured-yet

# Read-only Authentik API token for the portal's admin "Access overview" page
# (shows which users can access each app). Create a service account + token in
# Authentik — see the README ("Access overview"). Leave empty to disable the
# page (it then shows a "not configured" notice instead of crashing).
AUTHENTIK_API_TOKEN=

# Read-only Authentik API token for the Medewerkers app's "Toegang (Authentik)"
# panel (shows a person's groups + the apps those groups grant). Create with:
#   sh scripts/ak-exec.sh scripts/add-medewerkers-readonly-token.py
# Leave empty to disable the panel (it then shows "koppeling niet geconfigureerd").
MEDEWERKERS_AUTHENTIK_TOKEN=
