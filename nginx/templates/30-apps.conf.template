# Application server blocks. Every request is validated by Authentik's
# embedded outpost (forward auth) before it reaches the app — see
# snippets/forward-auth.conf. To add a fifth app, copy a block, change
# server_name and $app_upstream, and reload nginx.

server {
    listen 443 ssl;
    http2 on;
    server_name factorydocs.${BASE_DOMAIN};
    include /etc/nginx/snippets/ssl.conf;
    set $app_upstream http://app-factorydocs:3001;
    include /etc/nginx/snippets/forward-auth.conf;
}

