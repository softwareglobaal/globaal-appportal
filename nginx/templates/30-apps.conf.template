server {
    listen 443 ssl;
    http2 on;
    server_name omv.${BASE_DOMAIN};
    include /etc/nginx/snippets/ssl.conf;
    # Upstream is env-configurable so the same config works both ways:
    #  - local dev:  OMV_UPSTREAM=http://app-omv:3005      (the demo container)
    #  - on the VM:  OMV_UPSTREAM=http://host.docker.internal:5000  (real OMV app)
    set $app_upstream ${OMV_UPSTREAM};
    include /etc/nginx/snippets/forward-auth.conf;
}

