server {
    listen 443 ssl;
    http2 on;
    server_name facturatie.${BASE_DOMAIN};
    include /etc/nginx/snippets/ssl.conf;

    client_max_body_size 250m;
    proxy_read_timeout 600s;
    send_timeout 600s;

    set $app_upstream http://172.17.0.1:8765;
    include /etc/nginx/snippets/forward-auth.conf;
}
